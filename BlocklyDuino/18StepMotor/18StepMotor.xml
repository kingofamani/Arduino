<xml xmlns="http://www.w3.org/1999/xhtml">
  <block type="customcode_head" id="3" inline="true" x="88" y="13">
    <value name="text">
      <block type="text" id="4">
        <field name="TEXT">#include &lt;Stepper.h&gt;</field>
      </block>
    </value>
    <next>
      <block type="customcode_head" id="25" inline="true">
        <value name="text">
          <block type="text" id="26">
            <field name="TEXT">int steps=2048;</field>
          </block>
        </value>
        <next>
          <block type="customcode_head" id="7" inline="true">
            <value name="text">
              <block type="text" id="8">
                <field name="TEXT">Stepper myStepper(steps, 8, 10, 9, 11);</field>
              </block>
            </value>
          </block>
        </next>
      </block>
    </next>
  </block>
  <block type="initializes_setup" id="9" x="88" y="138">
    <statement name="CONTENT">
      <block type="serial_init" id="10">
        <field name="SPEED">9600</field>
        <next>
          <block type="customcode_code" id="11" inline="true">
            <value name="text">
              <block type="text" id="12">
                <field name="TEXT">myStepper.setSpeed(13);</field>
              </block>
            </value>
          </block>
        </next>
      </block>
    </statement>
    <next>
      <block type="initializes_loop" id="13">
        <statement name="CONTENT">
          <block type="controls_for" id="14" inline="true">
            <field name="VAR">i</field>
            <value name="FROM">
              <block type="math_number" id="15">
                <field name="NUM">0</field>
              </block>
            </value>
            <value name="TO">
              <block type="math_number" id="16">
                <field name="NUM">10</field>
              </block>
            </value>
            <statement name="DO">
              <block type="customcode_code" id="17" inline="true">
                <value name="text">
                  <block type="text" id="18">
                    <field name="TEXT">myStepper.step(steps);</field>
                  </block>
                </value>
              </block>
            </statement>
            <next>
              <block type="delay_custom" id="19" inline="false">
                <value name="DELAY_TIME">
                  <block type="math_number" id="20">
                    <field name="NUM">500</field>
                  </block>
                </value>
                <next>
                  <block type="customcode_code" id="21" inline="true">
                    <value name="text">
                      <block type="text" id="22">
                        <field name="TEXT">myStepper.step(-steps);</field>
                      </block>
                    </value>
                    <next>
                      <block type="delay_custom" id="23" inline="false">
                        <value name="DELAY_TIME">
                          <block type="math_number" id="24">
                            <field name="NUM">500</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
      </block>
    </next>
  </block>
